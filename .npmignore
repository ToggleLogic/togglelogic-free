# Defense-in-depth: package.json "files" is the allowlist (ships only src/,
# openclaw.plugin.json, LICENSE, README.md). This .npmignore additionally
# excludes anything that must NEVER ship, in case the allowlist is ever loosened.

# Paid / patented — must never ship in the free package
**/usage-tracker.js
**/registry-pricing.js
**/execution-estimate.js
**/dispatch/**
**/*classifier*.js
**/normalized.json
.toggle_registry/**
**/togglelogic-intelligence/**

# SAM-internal
**/turn-end-capture.js
**/sam-memory-bridge.js
**/redaction/**

# Repo / dev cruft
.git
.gitignore
**/*.bak*
LICENSE.bak-*
LICENSE.*.bak
**/.DS_Store

# CAVEAT (2026-06-18): npm/clawhub FORCE-INCLUDE any file whose name starts with
# LICENSE / README / NOTICE / COPYING / CHANGELOG — ignoring this .npmignore AND
# package.json "files". A LICENSE-prefixed backup (e.g. LICENSE.bak-*) WILL still be
# packed despite the rules above. Reliable defense: do NOT keep LICENSE-prefixed
# backups in the package dir — back them up elsewhere or rename without a LICENSE prefix.
**/__pycache__/**
**/*.test.js
test/**
tests/**
node_modules/**
